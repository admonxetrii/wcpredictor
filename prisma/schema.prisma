generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js Required Models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  // App-specific fields
  username               String? @unique
  passwordHash           String?
  role                   String  @default("USER") // USER | ADMIN
  isActive               Boolean @default(false)   // Closed signup, active by default is false
  finalWinnerPrediction  String? // Team code for tournament winner prediction
  amountPaid             Int     @default(0)       // Amount paid towards the NRS 1,000 fee

  totalPoints Int @default(0)

  accounts    Account[]
  sessions    Session[]
  predictions Prediction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@map("password_reset_tokens")
}

// ─── Application Models ──────────────────────────────────────────────────────

model Match {
  id          String   @id @default(cuid())
  matchNumber Int      @unique // FIFA match number
  teamA       String   // Team country code (e.g., "USA")
  teamB       String   // Team country code (e.g., "MEX")
  teamAName   String   // Full team name
  teamBName   String   // Full team name
  groupName   String?  // Group letter (A-L), null for knockout
  venue       String   // Stadium name
  city        String   // Host city
  kickoffTime DateTime // UTC kickoff time

  // Actual results (filled in by admin after match is played)
  actualScoreA    Int?
  actualScoreB    Int?
  actualGameTime  String? // FULL_TIME | EXTRA_TIME | PENALTY (knockout only)

  stage String // GROUP | ROUND_OF_32 | ROUND_OF_16 | QUARTER_FINAL | SEMI_FINAL | THIRD_PLACE | FINAL

  // For knockout matches: description of which position feeds in
  slotDescription String?

  predictions Prediction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("matches")
}

model Prediction {
  id     String @id @default(cuid())
  userId String @map("user_id")
  matchId String @map("match_id")

  predictedScoreA   Int
  predictedScoreB   Int
  predictedGameTime String? // FULL_TIME | EXTRA_TIME | PENALTY (knockout only)

  pointsAwarded Int @default(0)

  // Flag for "Unique Predictor Prize" in knockout
  isUniquePredictorPrize Boolean @default(false) @map("is_unique_predictor_prize")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, matchId]) // One prediction per user per match
  @@map("predictions")
}
